# ============================================================
# AI-Gateway Environment Configuration
# ============================================================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=DEBUG

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# --- llama.cpp Server ---
LLAMACPP_BASE_URL=http://127.0.0.1:8080
LLAMACPP_API_KEY=

# --- Ollama (optional) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- OpenAI Compatible (optional) ---
OPENAI_BASE_URL=
OPENAI_API_KEY=

# --- Model Configuration ---
MODEL_NAME=qwen2.5-7b-instruct-q4_k_m
MODEL_CONTEXT_LENGTH=8192
MODEL_MAX_SLOTS=4
MODEL_KV_BUDGET_BYTES=8589934592

# --- Token Budget ---
SAFE_KV_BUDGET_RATIO=0.75
MAX_CONCURRENT_REQUESTS=10

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# --- SSE ---
SSE_HEARTBEAT_INTERVAL_SEC=15
SSE_STREAM_MAX_LENGTH=10000

# --- Agent ---
AGENT_MAX_STEPS=20
AGENT_MAX_LLM_CALLS=15
AGENT_MAX_TOOL_CALLS=10
AGENT_TOOL_TIMEOUT_MS=30000
AGENT_MAX_RUNTIME_SEC=300

# --- RAG ---
RAG_DEFAULT_TOP_K=5
RAG_RERANK_TOP_K=3
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50

# --- Benchmark ---
BENCHMARK_DEFAULT_CONCURRENCY=10
BENCHMARK_DEFAULT_REQUESTS=50